<header class="flex items-center justify-between whitespace-nowrap border-b-4 border-red-500 bg-yellow-400 px-6 py-4 md:px-20 lg:px-40">
  <div class="flex items-center gap-3">
    <h1 class="text-red-500 text-2xl md:text-3xl font-black leading-tight tracking-tighter">
      <%= link_to "飯店図鑑", root_path, class: "hover:underline" %>
    </h1>
  </div>

  <div class="flex items-center gap-4">
    <button class="hidden md:flex items-center gap-2 text-red-500 font-bold px-4 py-2 hover:bg-red-500/10 rounded-lg transition">
      <span class="material-symbols-outlined"></span>
      <span>地図から探す</span>
    </button>

    <% if user_signed_in? %>
      <div class="flex items-center gap-4">
        <span class="text-red-500 font-semibold">
          ようこそ、<%= current_user.username %>さん
        </span>

        <%= link_to "Logout",
            destroy_user_session_path,
            data: { turbo_method: :delete },
            class: "flex items-center justify-center rounded-full h-11 px-6 bg-red-500 text-white text-sm font-bold shadow-lg hover:bg-red-600 transition" %>
      </div>
    <% else %>
      <%= link_to "Login",
          new_user_session_path,
          class: "flex min-w-[100px] cursor-pointer items-center justify-center rounded-full h-11 px-6 bg-red-500 text-white text-sm font-bold shadow-lg hover:bg-red-600 transition" %>
    <% end %>
  </div>
</header>