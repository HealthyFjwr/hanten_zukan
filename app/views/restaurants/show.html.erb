<% breadcrumb :restaurant, @restaurant %>
<div class="container mx-auto p-6 max-w-2xl">
  <%# ヒーローカード %>
  <div class="relative bg-red-800 rounded-2xl p-7 mb-5 overflow-hidden">
    <div class="absolute -right-5 -top-5 w-32 h-32 border-[12px] border-white/10 rounded-full"></div>
    <div class="absolute right-8 top-8 w-16 h-16 border-8 border-white/10 rounded-full"></div>

    <h1 class="text-2xl font-bold text-white mb-3">
      <%= @restaurant.name %>
    </h1>
    <p class="text-sm text-white/70 flex items-center gap-1">
      📍 <%= @restaurant.address.presence || "住所情報なし" %>
    </p>

    <div class="absolute top-5 right-5">
      <%= render 'bookmark_buttons', restaurant: @restaurant %>
    </div>
  </div>

  <%# タブ %>
  <div x-data="{ tab: 'info' }">
    <div class="flex border-b border-gray-200 mb-5">
      <button @click="tab = 'info'"
        :class="tab === 'info' ? 'border-b-2 border-red-800 text-red-800' : 'text-gray-400'"
        class="px-6 py-3 text-sm font-medium">
        店舗情報
      </button>
      <button @click="tab = 'review'"
        :class="tab === 'review' ? 'border-b-2 border-red-800 text-red-800' : 'text-gray-400'"
        class="px-6 py-3 text-sm font-medium">
        レビュー
      </button>
    </div>

    <%# 店舗情報タブ %>
    <div x-show="tab === 'info'">
      <%# マップ %>
      <div class="rounded-2xl overflow-hidden mb-5" style="height: 200px;">
        <div id="map" style="height: 100%;"></div>
      </div>
      <script>
        function initMap() {
          const position = { lat: <%= @restaurant.latitude %>, lng: <%= @restaurant.longitude %> };
          const map = new google.maps.Map(document.getElementById("map"), { zoom: 16, center: position });
          new google.maps.Marker({ position: position, map: map });
        }
        document.addEventListener("turbo:load", function() {
          if (document.getElementById("map") && typeof google !== 'undefined') {
            initMap();
          }
        });
      </script>

      <%# 電話・サイト %>
      <div class="grid grid-cols-2 gap-3 mb-5">
        <% if @restaurant.phone_number.present? %>
          <div class="bg-white border border-gray-100 rounded-xl p-4">
            <p class="text-xs tracking-widest text-gray-400 mb-1">電話番号</p>
            <p class="text-sm font-medium">📞 <%= @restaurant.phone_number %></p>
          </div>
        <% end %>
        <% if @restaurant.website.present? %>
          <div class="bg-white border border-gray-100 rounded-xl p-4">
            <p class="text-xs tracking-widest text-gray-400 mb-1">公式サイト</p>
            <%= link_to "サイトを見る →", @restaurant.website, target: "_blank",
                class: "text-sm font-medium text-red-800 hover:underline" %>
          </div>
        <% end %>
      </div>

      <%# 営業時間 %>
      <% if @restaurant.opening_hours["weekdayDescriptions"].present? %>
        <div class="bg-white border border-gray-100 rounded-xl p-4">
          <p class="text-xs tracking-widest text-gray-400 mb-3">営業時間</p>
          <% @restaurant.opening_hours["weekdayDescriptions"].each do |line| %>
            <p class="text-sm py-2 border-b border-gray-100 last:border-none"><%= line %></p>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# レビュータブ %>
    <div x-show="tab === 'review'">
      <%# 投稿フォーム %>
      <% if user_signed_in? %>
        <%= form_with model: [@restaurant, Comment.new], local: false do |f| %>
          <div class="mb-3">
            <%= f.text_area :body, placeholder: "コメントを入力してください",
                class: "w-full border border-gray-200 rounded-xl p-3 text-sm resize-none h-24" %>
          </div>
          <div class="flex justify-end">
            <%= f.submit "投稿する",
                class: "bg-red-800 text-white text-sm px-5 py-2 rounded-xl hover:bg-red-700" %>
          </div>
        <% end %>
      <% else %>
        <p class="text-sm text-gray-400">コメントするには<%= link_to "ログイン", new_user_session_path, class: "text-red-800 underline" %>してください</p>
      <% end %>

      <%# コメント一覧 %>
      <div class="mt-6 space-y-4">
        <% @restaurant.comments.order(created_at: :desc).each do |comment| %>
          <div class="bg-white border border-gray-100 rounded-xl p-4">
            <div class="flex justify-between items-center mb-2">
              <p class="text-sm font-medium"><%= comment.user.username %></p>
              <p class="text-xs text-gray-400"><%= comment.created_at.strftime("%Y/%m/%d") %></p>
            </div>
            <p class="text-sm text-gray-700"><%= comment.body %></p>

            <% if user_signed_in? && comment.user == current_user %>
              <div class="flex gap-3 mt-3">
                <%# 編集ボタン（インライン編集用） %>
                <button class="text-xs text-gray-400 hover:text-red-800">編集</button>
                <%= link_to "削除", restaurant_comment_path(@restaurant, comment),
                    data: { turbo_method: :delete, turbo_confirm: "削除しますか？" },
                    class: "text-xs text-gray-400 hover:text-red-800" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>