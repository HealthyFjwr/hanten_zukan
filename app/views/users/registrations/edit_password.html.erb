<div class="max-w-md mx-auto my-20 px-6">
  <h2 class="text-2xl font-black text-red-500 italic mb-8">パスワード変更</h2>

  <%= form_with model: resource, url: update_password_setting_path, method: :patch do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="mb-4">
      <%= f.label :current_password, "現在のパスワード", class: "block text-sm font-bold text-gray-700 mb-2" %>
      <%= f.password_field :current_password, class: "w-full border-2 border-gray-200 rounded-lg px-4 py-3 focus:outline-none focus:border-red-500 transition" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, "新しいパスワード", class: "block text-sm font-bold text-gray-700 mb-2" %>
      <%= f.password_field :password, class: "w-full border-2 border-gray-200 rounded-lg px-4 py-3 focus:outline-none focus:border-red-500 transition" %>
    </div>

    <div class="mb-6">
      <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "block text-sm font-bold text-gray-700 mb-2" %>
      <%= f.password_field :password_confirmation, class: "w-full border-2 border-gray-200 rounded-lg px-4 py-3 focus:outline-none focus:border-red-500 transition" %>
    </div>

    <div>
      <%= f.submit "パスワードを変更する", class: "w-full bg-red-500 text-white font-bold py-3 rounded-lg hover:bg-red-600 transition cursor-pointer" %>
    </div>
  <% end %>
</div>