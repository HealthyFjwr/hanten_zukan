<div>
  <h2 class="text-xl font-semibold mb-4">最近追加された店舗</h2>

  <% if @recent_restaurants.any? %>
    <div class="overflow-hidden bg-white shadow rounded-lg border border-gray-300 w-full">
      <table class="w-full border-collapse">
        <thead class="bg-gray-100">
          <tr>
            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700 border border-gray-300">
              店名
            </th>
            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700 border border-gray-300">
              登録日時
            </th>
            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700 border border-gray-300">
              住所
            </th>
          </tr>
        </thead>

        <tbody>
          <% @recent_restaurants.each do |restaurant| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 border border-gray-300">
                <%= restaurant.name %>
              </td>
              <td class="px-6 py-4 border border-gray-300 text-gray-600">
                <%= restaurant.created_at.strftime("%Y-%m-%d %H:%M") %>
              </td>
              <td class="px-6 py-4 border border-gray-300">
                <%= restaurant.address %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-gray-500">
      まだ店舗が登録されていません。
    </p>
  <% end %>
</div>