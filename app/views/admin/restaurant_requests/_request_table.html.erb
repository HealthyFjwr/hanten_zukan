<% if requests.any? %>
  <div class="overflow-hidden bg-white shadow rounded-lg border border-gray-300">
    <table class="w-full border-collapse">
      <thead class="bg-gray-100">
        <tr>
          <th class="px-4 py-3 border border-gray-300 text-left text-sm font-semibold text-gray-700">申請者</th>
          <th class="px-4 py-3 border border-gray-300 text-left text-sm font-semibold text-gray-700">都道府県</th>
          <th class="px-4 py-3 border border-gray-300 text-left text-sm font-semibold text-gray-700">市町村</th>
          <th class="px-4 py-3 border border-gray-300 text-left text-sm font-semibold text-gray-700">店名</th>
          <th class="px-4 py-3 border border-gray-300 text-left text-sm font-semibold text-gray-700">申請日</th>
          <% if show_actions %>
            <th class="px-4 py-3 border border-gray-300 text-center text-sm font-semibold text-gray-700" colspan="3">操作</th>
          <% end %>
        </tr>
      </thead>

      <tbody>
        <% requests.each do |req| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 border border-gray-300 text-sm">
              <%= req.user.username %>
            </td>
            <td class="px-4 py-3 border border-gray-300 text-sm">
              <%= req.prefecture %>
            </td>
            <td class="px-4 py-3 border border-gray-300 text-sm">
              <%= req.city %>
            </td>
            <td class="px-4 py-3 border border-gray-300 text-sm font-medium">
              <%= req.name %>
            </td>
            <td class="px-4 py-3 border border-gray-300 text-sm text-gray-500">
              <%= req.created_at.strftime("%Y-%m-%d") %>
            </td>

            <% if show_actions %>
              <!-- 承認 -->
              <td class="px-4 py-3 border border-gray-300 text-center">
                <%= button_to "承認",
                    approve_admin_restaurant_request_path(req),
                    method: :patch,
                    class: "px-3 py-1 bg-green-500 text-white text-sm rounded hover:bg-green-600 transition" %>
              </td>

              <!-- 却下 -->
              <td class="px-4 py-3 border border-gray-300 text-center">
                <%= button_to "却下",
                    reject_admin_restaurant_request_path(req),
                    method: :patch,
                    data: { turbo_confirm: '却下しますか？' },
                    class: "px-3 py-1 bg-yellow-500 text-white text-sm rounded hover:bg-yellow-600 transition" %>
              </td>

              <!-- 削除 -->
              <td class="px-4 py-3 border border-gray-300 text-center">
                <%= button_to "削除",
                    admin_restaurant_request_path(req),
                    method: :delete,
                    data: { turbo_confirm: '削除しますか？' },
                    class: "px-3 py-1 bg-red-500 text-white text-sm rounded hover:bg-red-600 transition" %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-gray-500 py-4">該当する申請はありません</p>
<% end %>
