<div class="w-full">

  <h1 class="text-2xl font-bold mb-4">飲食店追加</h1>

  <!-- DB件数表示 -->
  <% if defined?(@restaurant_count) %>
    <div class="mb-6 p-4 border border-gray-200 rounded-lg bg-white">
      DB登録店舗数: <strong class="text-lg"><%= @restaurant_count %></strong> 件
    </div>
  <% end %>

  <!-- 検索フォーム（GETなのでCSRFトークン不要） -->
  <%= form_with url: search_admin_search_restaurants_path, method: :get, local: true do |f| %>
    <div class="flex gap-3 mb-6 flex-wrap">
      <%= f.text_field :prefecture,
          placeholder: "都道府県",
          value: params[:prefecture],
          class: "px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-400 w-40" %>

      <%= f.text_field :city,
          placeholder: "市町村",
          value: params[:city],
          class: "px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-400 w-40" %>

      <%= f.text_field :keyword,
          placeholder: "店名",
          value: params[:keyword],
          class: "px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-400 w-80" %>

      <%= f.submit "検索",
          class: "px-4 py-2 bg-red-500 text-white rounded-md hover:bg-red-600 transition cursor-pointer" %>
    </div>
  <% end %>

  <!-- 検索結果 -->
  <% if @query.present? %>
    <p class="mb-4">
      検索ワード: <strong><%= @query %></strong>
    </p>

    <% if @candidates.present? %>
      <!-- 候補選択フォーム（POSTなのでform_withがCSRFトークンを自動付与） -->
      <%= form_with url: admin_search_restaurants_path, method: :post, local: true do |f| %>
        <div class="flex flex-col gap-3 mb-4">
          <% selected_ids = Array(params[:place_ids]).map(&:to_s) %>

          <% @candidates.each do |c| %>
            <label class="flex gap-3 items-start p-4 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50">
              <%= check_box_tag "place_ids[]",
                  c[:place_id],
                  selected_ids.include?(c[:place_id].to_s),
                  class: "mt-1" %>
              <div>
                <div class="font-semibold"><%= c[:name] %></div>
                <div class="text-gray-500 text-sm"><%= c[:address] %></div>
              </div>
            </label>
          <% end %>
        </div>

        <%= f.submit "選択を確定",
            class: "px-4 py-2 bg-red-500 text-white rounded-md hover:bg-red-600 transition cursor-pointer" %>
      <% end %>
    <% else %>
      <p class="text-gray-500">該当なし</p>
    <% end %>
  <% end %>

</div>
